{
  "Proxy": {
    "ListenPort": 1433,
    "ListenAddress": "0.0.0.0",
    "MaxConcurrentConnections": 100,
    "Certificate": {
      "Path": "",
      "Password": "",
      "AutoGenerate": true
    },
    "AuditLogPath": "logs/audit-.log",
    "Datadog": {
      "Enabled": false,
      "ApiKey": "",
      "Service": "tailsqlproxy",
      "Source": "csharp",
      "Tags": ["env:development"]
    }
  },
  "TargetServer": {
    "Host": "yourserver.database.windows.net",
    "Port": 1433
  },
  "Rules": {
    "BypassUsers": [],
    "BypassAppNames": [],
    "BypassClientIps": [],
    "SqlInjection": {
      "Enabled": true,
      "BlockOnParseErrors": false,
      "CustomPatterns": []
    },
    "UnboundedSelect": {
      "Enabled": true
    },
    "UnboundedDelete": {
      "Enabled": true
    },
    "SsmsMetadata": {
      "Enabled": true,
      "BlockedProcedures": [
        "sp_helpdb",
        "sp_helplogins",
        "sp_describe_undeclared_parameters",
        "sp_describe_first_result_set",
        "sp_oledb_ro_usrname",
        "sp_help",
        "sp_columns",
        "sp_tables",
        "sp_fkeys",
        "sp_pkeys",
        "sp_statistics",
        "sp_sproc_columns",
        "sp_stored_procedures",
        "sp_table_privileges",
        "sp_column_privileges"
      ],
      "BlockedSystemViews": [
        "sys.databases",
        "sys.objects",
        "sys.tables",
        "sys.columns",
        "sys.all_objects",
        "sys.all_columns",
        "sys.schemas",
        "sys.types",
        "sys.indexes",
        "sys.index_columns",
        "sys.foreign_keys",
        "sys.foreign_key_columns",
        "sys.key_constraints",
        "sys.views",
        "sys.procedures",
        "sys.parameters",
        "sys.sql_modules",
        "sys.syscolumns",
        "sys.sysobjects"
      ],
      "BlockedSchemas": [
        "INFORMATION_SCHEMA"
      ],
      "AllowedPatterns": []
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
