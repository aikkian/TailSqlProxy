{
  "Proxy": {
    "ListenPort": 1433,
    "ListenAddress": "0.0.0.0",
    "MaxConcurrentConnections": 100,
    "Certificate": {
      "Path": "",
      "Password": "",
      "AutoGenerate": true
    },
    "AuditLogPath": "logs/audit-.log",
    "AuditJsonLogPath": "logs/audit-json-.log",
    "Datadog": {
      "Enabled": false,
      "ApiKey": "",
      "Service": "tailsqlproxy",
      "Source": "csharp",
      "Tags": ["env:development"]
    }
  },
  "TargetServer": {
    "Host": "<your-db>.database.windows.net",
    "Port": 1433
  },
  "Rules": {
    "BypassUsers": [],
    "BypassAppNames": [],
    "BypassClientIps": [],
    "AccessControl": {
      "Enabled": false,
      "Policies": [
        {
          "Name": "Block non-HR from Salary",
          "Priority": 100,
          "Action": "Deny",
          "Users": [],
          "ObjectPattern": "^(dbo\\.)?Employees$",
          "Columns": ["Salary", "SSN", "BankAccount"],
          "Operations": ["Select", "Update"]
        },
        {
          "Name": "Block DELETE on critical tables",
          "Priority": 90,
          "Action": "Deny",
          "ObjectPattern": "^(dbo\\.)?(Customers|Orders|Payments)$",
          "Operations": ["Delete"]
        }
      ]
    },
    "SqlInjection": {
      "Enabled": true,
      "BlockOnParseErrors": false,
      "CustomPatterns": []
    },
    "UnboundedSelect": {
      "Enabled": true
    },
    "UnboundedDelete": {
      "Enabled": true
    },
    "SsmsMetadata": {
      "Enabled": true,
      "BlockedAppNames": [
        "Microsoft SQL Server Management Studio",
        "Microsoft SQL Server Management Studio - Query",
        "SQLServerCEIP",
        "azdata"
      ],
      "BlockServerProperties": true,
      "BlockDmvs": true,
      "BlockSetStatements": false,
      "BlockedProcedures": [
        "sp_helpdb",
        "sp_helplogins",
        "sp_helptext",
        "sp_help",
        "sp_helpindex",
        "sp_helpsort",
        "sp_helprotect",
        "sp_helpconstraint",
        "sp_describe_undeclared_parameters",
        "sp_describe_first_result_set",
        "sp_describe_parameter_encryption",
        "sp_oledb_ro_usrname",
        "sp_columns",
        "sp_columns_100",
        "sp_columns_100_rowset",
        "sp_tables",
        "sp_fkeys",
        "sp_pkeys",
        "sp_statistics",
        "sp_sproc_columns",
        "sp_stored_procedures",
        "sp_table_privileges",
        "sp_column_privileges",
        "sp_special_columns",
        "sp_databases",
        "sp_datatype_info",
        "sp_datatype_info_100",
        "sp_helpuser",
        "sp_helprole",
        "sp_helprolemember",
        "sp_helpsrvrolemember"
      ],
      "BlockedSystemViews": [
        "sys.databases",
        "sys.objects",
        "sys.tables",
        "sys.columns",
        "sys.all_objects",
        "sys.all_columns",
        "sys.schemas",
        "sys.types",
        "sys.systypes",
        "sys.synonyms",
        "sys.sql_modules",
        "sys.indexes",
        "sys.index_columns",
        "sys.foreign_keys",
        "sys.foreign_key_columns",
        "sys.key_constraints",
        "sys.check_constraints",
        "sys.default_constraints",
        "sys.views",
        "sys.procedures",
        "sys.parameters",
        "sys.triggers",
        "sys.computed_columns",
        "sys.identity_columns",
        "sys.sequences",
        "sys.extended_properties",
        "sys.server_principals",
        "sys.database_principals",
        "sys.database_permissions",
        "sys.server_permissions",
        "sys.database_role_members",
        "sys.configurations",
        "sys.syscolumns",
        "sys.sysobjects",
        "sys.sysindexes",
        "sys.sysusers",
        "sys.sysprocesses"
      ],
      "BlockedSchemas": [
        "INFORMATION_SCHEMA"
      ],
      "AllowedPatterns": []
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
